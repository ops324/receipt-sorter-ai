# ── フロント（ブラウザに露出してよい公開値）───────────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# ── サーバーレス関数 /api/ocr 専用（絶対にブラウザへ出さない）──────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...
ANTHROPIC_API_KEY=sk-ant-...
# OCR を許可するユーザーの auth.users.id（UUID）をカンマ区切りで。所有者＋友人のみ。
ALLOWED_USER_IDS=00000000-0000-0000-0000-000000000000
# 1ユーザーあたりの月次OCR上限（コスト天井）。未設定なら既定値。
MONTHLY_OCR_LIMIT=1000
# OCRに使うモデル（オーナーが一元固定。クライアントは選べない）。未設定なら最安の haiku。
# 許可値: claude-haiku-4-5-20251001 / claude-sonnet-4-6 / claude-opus-4-8 等
OCR_MODEL=claude-haiku-4-5-20251001
